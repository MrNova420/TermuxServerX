quick_start() {
    echo -e "\n${CYAN}[ Quick Start ]${NC}\n"
    echo "Starting essential services..."
    
    bash "$TSX_DIR/services/web/nginx.sh" start 2>/dev/null && log "Nginx" || true
    bash "$TSX_DIR/services/web/php.sh" start 2>/dev/null && log "PHP-FPM" || true
    bash "$TSX_DIR/services/database/redis.sh" start 2>/dev/null && log "Redis" || true
    bash "$TSX_DIR/services/storage/filebrowser.sh" start 2>/dev/null && log "FileBrowser" || true
    
    echo ""
    log "Essential services started!"
    echo "Access:"
    echo "  Web:  http://localhost:8080"
    echo "  Files: http://localhost:8081"
}

quick_stop() {
    echo -e "\n${YELLOW}[ Quick Stop ]${NC}\n"
    echo "Stopping all services..."
    
    pkill -f nginx 2>/dev/null && log "Nginx stopped" || true
    pkill -f php-fpm 2>/dev/null && log "PHP-FPM stopped" || true
    pkill -f redis 2>/dev/null && log "Redis stopped" || true
    pkill -f filebrowser 2>/dev/null && log "FileBrowser stopped" || true
    pkill -f minecraft 2>/dev/null && log "Minecraft stopped" || true
    
    echo ""
    warn "All services stopped"
}

install_category() {
    local cat=$1
    echo -e "\n${CYAN}[ Installing $cat ]${NC}\n"
    
    case $cat in
        web)
            bash "$TSX_DIR/services/web/nginx.sh" install
            bash "$TSX_DIR/services/web/php.sh" install
            bash "$TSX_DIR/services/web/caddy.sh" install
            ;;
        database)
            bash "$TSX_DIR/services/database/mariadb.sh" install
            bash "$TSX_DIR/services/database/postgresql.sh" install
            bash "$TSX_DIR/services/database/redis.sh" install
            ;;
        games)
            bash "$TSX_DIR/services/games/minecraft.sh" install
            bash "$TSX_DIR/services/games/pocketmine.sh" install
            ;;
        storage)
            bash "$TSX_DIR/services/storage/filebrowser.sh" install
            bash "$TSX_DIR/services/storage/syncthing.sh" install
            ;;
        dev)
            bash "$TSX_DIR/services/dev/code-server.sh" install
            bash "$TSX_DIR/services/dev/git.sh" install
            ;;
        media)
            bash "$TSX_DIR/services/media/jellyfin.sh" install
            ;;
        productivity)
            bash "$TSX_DIR/services/productivity/gitea.sh" install
            bash "$TSX_DIR/services/productivity/vaultwarden.sh" install
            bash "$TSX_DIR/services/productivity/bookstack.sh" install
            ;;
        network)
            bash "$TSX_DIR/services/network/cloudflared.sh" install
            bash "$TSX_DIR/services/network/ssh.sh" install
            ;;
        monitoring)
            bash "$TSX_DIR/services/monitoring/netdata.sh" install
            ;;
        all)
            bash "$TSX_DIR/install.sh"
            ;;
    esac
}

service_status_all() {
    echo -e "\n${CYAN}[ Service Status ]${NC}\n"
    printf "%-20s %-15s %s\n" "Service" "Status" "Port"
    echo "────────────────────────────────────────────"
    
    local services=(
        "nginx:8080"
        "php-fpm:9000"
        "mariadb:3306"
        "redis:6379"
        "minecraft:25565"
        "pocketmine:19135"
        "filebrowser:8081"
        "code-server:8443"
        "sshd:8022"
        "jellyfin:8096"
        "gitea:3000"
        "vaultwarden:8080"
        "netdata:19999"
    )
    
    for entry in "${services[@]}"; do
        IFS=':' read -r svc port <<< "$entry"
        if is_running "$svc"; then
            printf "%-20s ${GREEN}%-15s${NC} :%s\n" "$svc" "running" "$port"
        else
            printf "%-20s ${RED}%-15s${NC} :%s\n" "$svc" "stopped" "$port"
        fi
    done
}

