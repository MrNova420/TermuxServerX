case "${1:-help}" in
    services|list) show_all_services ;;
    start-all)
        for svc in nginx php-fpm mariadb redis; do
            bash "$TSX_DIR/manage" start "$svc" 2>/dev/null
        done
        log "All services started"
        ;;
    stop-all) quick_stop ;;
    quick-start) quick_start ;;
    quick-stop) quick_stop ;;
    install)
        install_category "${2:-all}"
        ;;
    status-all|status) service_status_all ;;
    guides|help|--help|-h) show_help ;;
    *) show_help ;;
esac
