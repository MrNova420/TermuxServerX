TSX_VERSION="2.0.0"
TSX_INSTALL_DATE="$(date)"
TSX_LAST_UPDATE="$(date)"

TSX_CPU_MODEL="Unknown"
TSX_CPU_ARCH="Unknown"
TSX_CPU_CORES="4"
TSX_TOTAL_RAM="4096"
TSX_AVAILABLE_RAM="2048"
TSX_RAM_PERCENT="50"
TSX_RAM_TIER="medium"

TSX_INTERNAL_PATH="/sdcard"
TSX_INTERNAL_SIZE="60000"
TSX_INTERNAL_USED="30000"
TSX_INTERNAL_AVAIL="30000"
TSX_EXTERNAL_PATH=""
TSX_STORAGE_TIER="good"

TSX_LOCAL_IP="192.168.1.100"
TSX_PUBLIC_IP="Unknown"
TSX_CONNECTION_TYPE="WiFi"
TSX_HAS_INTERNET="yes"

TSX_BATTERY_LEVEL="100"
TSX_CHARGING_STATUS="Unknown"
TSX_CPU_TEMP="40"

TSX_ANDROID_VERSION="13"
TSX_DEVICE_MODEL="Android Device"
TSX_DEVICE_MANUFACTURER="Unknown"
TSX_KERNEL_VERSION="6.0.0"

TSX_MAX_GAME_SERVERS="2"
TSX_DB_RAM="256M"
TSX_JAVA_RAM="1024M"
TSX_WEB_WORKERS="4"

TSX_WEBUI_PORT="8080"
TSX_WEBUI_USER="admin"
TSX_WEBUI_PASSWORD="admin"

TSX_DATA_DIR="$HOME/TermuxServerX/data"
TSX_LOGS_DIR="$HOME/TermuxServerX/logs"
TSX_BACKUP_DIR="$HOME/TermuxServerX/backups"

TSX_TUNNEL_ENABLED="false"
TSX_TUNNEL_URL=""
TSX_TUNNEL_TOKEN=""

TSX_AUTO_START="true"
TSX_WATCHDOG_ENABLED="true"
TSX_WATCHDOG_INTERVAL="60"
TSX_AUTO_CLEANUP="true"

TSX_OPTIMIZED_FOR_247="true"
